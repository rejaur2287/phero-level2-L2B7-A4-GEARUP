model User {
    id           String   @id @default(uuid())
    name         String
    email        String   @unique
    password     String
    phone        String?
    profileImage String?
    role         UserRole @default(CUSTOMER)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    gearItems    GearItem[]
    rentalOrders RentalOrder[]
    reviews      Review[]

    @@map("users")
}
